{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_GENERATED_TOKEN"
    },
    "controlUi": {
      "allowedOrigins": [],
      "allowInsecureAuth": false,
      "dangerouslyDisableDeviceAuth": false
    }
  },

  "discovery": {
    "mdns": { "mode": "off" }
  },

  "channels": {
    "telegram": {
      "dmPolicy": "pairing",
      "groups": {
        "*": { "requireMention": true }
      }
    }
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "tools": {
    "profile": "messaging",
    "deny": [
      "group:runtime",
      "sessions_spawn",
      "sessions_send",
      "gateway"
    ],
    "fs": { "workspaceOnly": true },
    "exec": {
      "security": "ask",
      "ask": "always"
    },
    "elevated": { "enabled": false }
  },

  "browser": {
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false,
      "hostnameAllowlist": []
    }
  },

  "logging": {
    "level": "info",
    "redactSensitive": "tools",
    "redactPatterns": [
      "sk-[a-zA-Z0-9]{20,}",
      "sk-ant-[a-zA-Z0-9-]{20,}",
      "Bearer [a-zA-Z0-9._-]+",
      "secret_[a-zA-Z0-9]*",
      "ghp_[a-zA-Z0-9]{36}",
      "gho_[a-zA-Z0-9]{36}"
    ]
  }
}
